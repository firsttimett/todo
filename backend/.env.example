# Copy this file to .env and fill in values before running `make dev-backend`.
# Used only when running the backend directly outside Docker (uv run uvicorn ...).
# For the standard Docker-based flow (`make dev`), all vars are set in docker-compose.yml.

ENV_NAME=local
GCP_PROJECT=nnow-local

# Firestore emulator must be running separately (e.g. `make dev` starts it on :8090)
FIRESTORE_EMULATOR_HOST=localhost:8090

# JWT keys — generated by `make setup`
JWT_PUBLIC_KEY_FILE=../secrets/jwt_public_key.pem
JWT_PRIVATE_KEY_FILE=../secrets/jwt_private_key.pem

# OTP bypass code — use this code instead of a real email OTP in local dev
OTP_BYPASS_CODE=652093

# Optional — leave empty to print OTP codes to stdout instead of sending email
RESEND_API_KEY=
RESEND_FROM_EMAIL=
